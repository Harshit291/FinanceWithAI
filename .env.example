# FinAI — environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file matching .env*
# See docs/ENV_VARIABLES.md for full descriptions.

# --- LLM providers (set any subset; failover ranks them by quality — ADR-0007) ---
# At least one is required. More keys = more combined free quota + redundancy.
GROQ_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
OPENROUTER_API_KEY=
FASTAPI_URL=http://localhost:8000

# --- Anthropic (swap in when key is available; will join the failover chain) ---
ANTHROPIC_API_KEY=
# Note: per-provider models are configured in services/app/pipeline/_shared.py.
# These env vars are kept for legacy callers; the multi-provider helper does not read them.
LLM_SYNTHESIS_MODEL=llama-3.3-70b-versatile
LLM_CLASSIFIER_MODEL=llama-3.1-8b-instant

# --- Market data providers ---
FINNHUB_API_KEY=
INDIANAPI_API_KEY=

# --- Database + cache (session 3) ---
# SQLite (dev): DATABASE_URL=file:./dev.db
# Supabase (prod): DATABASE_URL=postgresql://...
DATABASE_URL=file:./dev.db
REDIS_URL=

# --- Auth (session 3) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional / forthcoming ---
# SENTRY_DSN=
# RATE_LIMIT_REPORTS_PER_DAY=20
# EODHD_API_KEY=
