# FinAI — environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file matching .env*
# See docs/ENV_VARIABLES.md for full descriptions.

# --- Anthropic (required in dev + prod; session 2 onwards) ---
ANTHROPIC_API_KEY=
LLM_SYNTHESIS_MODEL=claude-opus-4-7
LLM_CLASSIFIER_MODEL=claude-haiku-4-5

# --- Market data providers ---
FINNHUB_API_KEY=
INDIANAPI_API_KEY=

# --- Database + cache (session 3) ---
DATABASE_URL=
REDIS_URL=

# --- Auth (session 3) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional / forthcoming ---
# SENTRY_DSN=
# RATE_LIMIT_REPORTS_PER_DAY=20
# EODHD_API_KEY=
