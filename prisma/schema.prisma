generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// ── NextAuth.js adapter tables ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ───────────────────────────────────────────────────────────────

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime        @default(now())
  accounts       Account[]
  sessions       Session[]
  watchlist      WatchlistItem[]
  watchlists     Watchlist[]
  reports        AiReport[]
  paperAccount   PaperAccount?
  paperPositions PaperPosition[]
  paperTrades    PaperTrade[]
}

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]

  @@unique([userId, name])
}

model WatchlistItem {
  id          String    @id @default(cuid())
  userId      String
  symbol      String
  exchange    String
  addedAt     DateTime  @default(now())
  watchlistId String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchlistGroup Watchlist? @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, watchlistId])
}

model AiReport {
  id         String   @id @default(cuid())
  userId     String
  symbol     String
  reportId   String
  reportJson String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
  @@index([userId, symbol, createdAt])
}

model AnonymousReport {
  id        String   @id @default(cuid())
  ipAddress String
  createdAt DateTime @default(now())

  @@index([ipAddress, createdAt])
}

// ── Paper Trading Models ─────────────────────────────────────────────────────

model PaperAccount {
  id               String   @id @default(cuid())
  userId           String   @unique
  cashBalance      Float    @default(100000.0)
  totalRealizedPnl Float    @default(0.0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaperPosition {
  id           String   @id @default(cuid())
  userId       String
  symbol       String
  quantity     Float
  averagePrice Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
}

model PaperTrade {
  id             String   @id @default(cuid())
  userId         String
  symbol         String
  side           String   // "BUY" or "SELL"
  quantity       Float
  executionPrice Float
  realizedPnl    Float?   // Only applicable for SELL
  timestamp      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, symbol])
  @@index([userId, timestamp])
}
